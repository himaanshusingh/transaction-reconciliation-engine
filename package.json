{
  "name": "transaction-reconciliation-engine",
  "version": "1.0.0",
  "description": "Reconciles user-reported crypto transactions against exchange exports with configurable tolerances.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "ingest": "node src/scripts/ingest.js",
    "reconcile": "node src/scripts/reconcile.js",
    "test": "node --test tests/*.test.js",
    "build": "npm install"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongodb": "^6.8.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
